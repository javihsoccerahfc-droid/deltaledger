# Copy this file to .env (local dev) and fill in real values.
# Never commit .env with real credentials -- it's already in .gitignore.

# Required. A standard Postgres connection string.
#
# Local/Docker Postgres example:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deltaledger
#
# Hosted Postgres (Vercel Postgres, Neon, Supabase, RDS, etc.) -- copy the
# connection string your provider gives you. Most hosted providers require
# SSL, which is assumed automatically for any non-localhost host (see
# db/client.ts). Example shape:
#   DATABASE_URL=postgresql://user:password@host.example.com:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deltaledger

# Optional. Force SSL on ("true") or off ("false") if the automatic
# localhost-vs-hosted heuristic in db/client.ts doesn't fit your setup.
# PGSSL=true

# Required for `npm test`, never used by the app itself. Point this at a separate,
# disposable database (name must contain "test") -- the test suite truncates every table
# between test files, and refuses to start if this isn't set or looks like DATABASE_URL above.
# There is deliberately no default here: the value depends on which Postgres role your local
# install actually has (e.g. "postgres" on a fresh Docker container, but your own OS username
# on many native installs) -- copy the shape below and adjust the role to match yours.
# You can also put this in a separate, gitignored .env.test file instead of .env.
#   TEST_DATABASE_URL=postgresql://<your-role>@localhost:5432/deltaledger_test
TEST_DATABASE_URL=postgresql://postgres@localhost:5432/deltaledger_test
